# DoaneEdgeGate configuration.
# These override appsettings.json. ASP.NET config uses __ as the section
# separator. Set them in the environment, in launchSettings.json, or (under IIS)
# in the app pool or web.config environmentVariables.
# ---------------------------------------------------------------------------

# Listen address (bind 0.0.0.0 per Doane standard).
ASPNETCORE_URLS=http://0.0.0.0:5058

# Run mode: Off (passthrough), Shadow (log-only), Active (rewrite).
# Ship Off. Move to Shadow to validate. Only Active after Phase 0 confirms the
# payload carries a UTC instant.
EdgeGate__Mode=Off

# Where to forward. Just the scheme://host[:port] of the Colleague Web API;
# the incoming path and query are appended unchanged.
EdgeGate__Downstream__BaseUrl=https://colleague-webapi.internal.doane.edu
EdgeGate__Downstream__TimeoutSeconds=100

# Which requests to watch. Methods default to POST,PUT. PathPatterns is empty by
# default (nothing matches) - fill index 0 (and 1, 2, ...) from Phase 0. A trailing
# * is a prefix match; otherwise it is an exact, case-insensitive match.
EdgeGate__Match__Methods__0=POST
EdgeGate__Match__PathPatterns__0=/ColleagueApi/put-the-real-IE-person-create-path-here

# Which fields to rewrite: FieldAllowlist (only named fields) or ShapeAll (any
# instant on a matched request). See docs/architecture.md section 5.
EdgeGate__Rewrite__Strategy=FieldAllowlist
EdgeGate__Rewrite__DateFieldNames__0=birthDate
EdgeGate__Rewrite__DateFieldNames__1=dateOfBirth
EdgeGate__Rewrite__DateFieldNames__2=dob

# On rewrite error: Open (forward original, never drop) or Closed (502). Use Open.
EdgeGate__Rewrite__FailMode=Open

# Only rewrite morning-UTC Z instants (the bug signature). Leave true.
EdgeGate__Rewrite__RequireMorningUtcForZ=true
