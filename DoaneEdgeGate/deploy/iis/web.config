<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\DoaneEdgeGate.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <!-- Set the real values here or at the App Pool level. -->
          <environmentVariable name="EdgeGate__Mode" value="Off" />
          <environmentVariable name="EdgeGate__Downstream__BaseUrl" value="https://colleague-webapi.internal.doane.edu" />
          <environmentVariable name="EdgeGate__Match__PathPatterns__0" value="/ColleagueApi/the-IE-person-create-path" />
          <!-- Required (via the X-Management-Key header) to call GET
               /api/v1/status and GET /api/v1/rewrites/recent — both expose
               operationally sensitive detail in production, including the
               actual unredacted applicant birth dates this gate
               intercepted. Generate with, e.g., PowerShell:
                 [System.Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
               No ASPNETCORE_ENVIRONMENT is set here, which means this
               deployment defaults to Production (ASP.NET Core's own
               default when unset) — so this key IS enforced unless you
               explicitly set ASPNETCORE_ENVIRONMENT to something else. -->
          <environmentVariable name="EdgeGate__Management__ApiKey" value="REPLACE_ME" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
