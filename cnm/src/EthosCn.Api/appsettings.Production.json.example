{
  "_comment": "Template for appsettings.Production.json. Copy to appsettings.Production.json (gitignored) and fill in. Any value here can also be supplied via env var with '__' replacing ':' — e.g. ColleagueWebApi:Username -> ColleagueWebApi__Username. See docs/cnm-configuration.md for the full reference.",

  "ConnectionStrings": {
    "CnmDb": "Server=<sql-host>;Database=<db>;User Id=<user>;Password=<pw>;Encrypt=true;TrustServerCertificate=false"
  },

  "Cnm": {
    "UseSqlite": false
  },

  "AzureAd": {
    "Authority": "https://login.microsoftonline.com/<tenant-id>/v2.0",
    "Audience": "<app-registration-client-id>"
  },

  "ColleagueWebApi": {
    "BaseUrl": "https://<colleague-web-api-host>",
    "Username": "<service-account>",
    "Password": "<service-account-password>",
    "Timeout": "00:00:30"
  },

  "Das": {
    "BaseUrl": "https://<das-host>",
    "Username": "<das-service-account>",
    "Password": "<das-service-account-password>"
  },

  "ColleagueSql": {
    "ConnectionString": "Server=<colleague-sql-host>;Database=<colleague-db>;User Id=<readonly-user>;Password=<pw>;Encrypt=true"
  },

  "Cors": {
    "AllowedOrigins": [
      "https://<console-host>",
      "https://<other-trusted-host>"
    ]
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
