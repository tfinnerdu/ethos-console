# Ethos API credentials
ETHOS_API_KEY=your-ethos-api-key-here
ETHOS_BASE_URL=https://integrate.elluciancloud.com

# Conductor integration (optional — used by the Replayer)
CONDUCTOR_API_KEY=
CONDUCTOR_URL=https://du-int.doane.edu/prod/conductor

# CNM integration — set to enable the CN Monitor tab
# Dev:  CNM_BASE_URL=http://localhost:5000  (DevAuth accepts requests without a token)
# Prod: CNM_BASE_URL=https://your-host/prod/cnm  +  CNM_API_KEY=<Azure AD service token>
CNM_BASE_URL=
CNM_API_KEY=

# Database — defaults to SQLite for local dev
# For PostgreSQL: DATABASE_URL=postgresql://user:pass@localhost:5432/ethos_console
DATABASE_URL=

# Flask settings
FLASK_ENV=development
SECRET_KEY=dev-secret-change-in-prod
PORT=5012

# UniData / Colleague Direct Query (optional - enables the Direct Query tab)
# Connect via uopy (Rocket Software's Python API for UniData/UniVerse)
# Account path is the full server-side path to the Colleague apphome directory
UNIDATA_HOST=
UNIDATA_PORT=31438
UNIDATA_USER=
UNIDATA_PASSWORD=
UNIDATA_ACCOUNT=

# Optional
BUS_POLL_INTERVAL=2
SILENCE_THRESHOLD_MINUTES=30
