# All-or-nothing mock mode. When true, every upstream call (Ethos, CNM,
# Colleague Web API, Conductor, UniData) returns fixture data and no real
# credential or host is used. The nav bar shows a MOCK badge, every API
# response carries an X-Mock-Mode: true header, and the health endpoint
# reports "mock": true. There is NO per-call fallback — it is mock or live,
# never a mix. Use this to demo or develop without credentials.
CONSOLE_MOCK_MODE=false

# Ethos environments. Every Ethos-touching tab uses the currently-active
# environment's credentials — this is the only place to put Ethos keys.
# Define up to 5 (ETHOS_ENV_1_* through ETHOS_ENV_5_*); a dropdown appears
# in the nav bar when 2+ are configured. Switching hot-swaps credentials
# without a restart and invalidates the GraphQL schema cache.
#
# ETHOS_ENV_n_GRAPHQL_KEY is optional — set it only when the bus key for
# that environment lacks GraphQL scope (e.g. a dev tenant where GraphQL
# resources can't be updated). Falls back to ETHOS_ENV_n_KEY.
ETHOS_ENV_1_NAME=Dev
ETHOS_ENV_1_URL=https://integrate.elluciancloud.com
ETHOS_ENV_1_KEY=
ETHOS_ENV_1_GRAPHQL_KEY=

ETHOS_ENV_2_NAME=Test
ETHOS_ENV_2_URL=https://integrate.elluciancloud.com
ETHOS_ENV_2_KEY=
ETHOS_ENV_2_GRAPHQL_KEY=

ETHOS_ENV_3_NAME=Prod
ETHOS_ENV_3_URL=https://integrate.elluciancloud.com
ETHOS_ENV_3_KEY=
ETHOS_ENV_3_GRAPHQL_KEY=

# Preselected environment at startup. Must match one of the ETHOS_ENV_n NAME
# values above (case-insensitive). If unset or it doesn't match, the first
# configured ETHOS_ENV_n is used.
DEFAULT_ENV=Dev

# Conductor integration (optional — used by the Replayer)
CONDUCTOR_API_KEY=
CONDUCTOR_URL=https://du-int.doane.edu/prod/conductor

# The Replay UI lets an operator override conductor_url per run (e.g. to
# point at a test/staging Conductor instead). CONDUCTOR_URL's own host is
# always allowed; list any *additional* hostnames here (comma-separated) to
# permit them too. Every other host is refused outright — the real
# CONDUCTOR_API_KEY is attached to every request, so an unrestricted
# override would hand that key to whatever host is supplied.
CONDUCTOR_ADDITIONAL_HOSTS=

# Database — defaults to SQLite for local dev
#
#
# Database — defaults to SQLite for local dev. Leave unset to use the
# default relative ethos_console.db file — that's almost always the right
# call locally. NOTE: Flask-SQLAlchemy resolves any *relative* sqlite path
# against the app's instance folder, not the process's working directory —
# so this actually lands in console/instance/ethos_console.db, not
# console/ethos_console.db. Check the app's startup log ("Database: SQLite
# — ...") for the exact resolved path if you go looking for the file.
#
# Accepts either a full DB URI (postgresql://user:pass@localhost:5432/ethos_console)
# or, matching the SF Mission Control sibling app's simpler DATABASE_PATH
# convention, just a plain filesystem path — e.g. sf_mission_control.db,
# /data/ethos_console.db, or C:\data\ethos_console.db. The app builds the
# correct sqlite:/// URI itself either way, so you never have to hand-count
# "how many slashes mean absolute" (a real, OS-specific footgun: 4 on Linux,
# 3 on Windows — getting it wrong fails with "unable to open database file").
#
# In production (FLASK_ENV=production, e.g. inside the k8s container, which
# always runs Linux regardless of what you develop on), a relative path
# (the default above) is refused at boot — that file lives in the
# container's ephemeral filesystem and vanishes on every redeploy. An
# absolute path is allowed instead, for a deliberate PVC-backed deployment
# (replicas: 1, strategy: Recreate — see k8s/secret-template.yaml). This
# distinction is production-only — start-local.ps1 always forces
# FLASK_ENV=development, so it never applies to a local run either way.
DATABASE_URL=

# Flask settings
FLASK_ENV=development
# SECRET_KEY signs the login session cookie (app/auth.py) as well as Flask's
# own session machinery generally. MUST be a real random value in any
# deployment that has AUTH_USERNAME/AUTH_PASSWORD set below — left at the
# default, the login gate can be bypassed by forging a session cookie.
# Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-in-prod
PORT=5012

# Single-credential login gate (app/auth.py) — gates every route except
# health checks. FAIL-CLOSED: if either of these is unset, every non-health
# route is blocked (503), not silently ungated. See docs/auth-gate-guide.md.
AUTH_USERNAME=
AUTH_PASSWORD=
# Secure cookie flag — leave "true" for any real deployment (HTTPS via
# Traefik/ingress); set "false" only for local http://localhost dev.
AUTH_COOKIE_SECURE=true
# How long a login session lasts before re-authenticating is required.
AUTH_SESSION_LIFETIME_HOURS=8
# If this deployment sits behind an ingress that strips a path prefix
# before forwarding (see k8s/ethos-console.yaml's Ingress) — e.g. Traefik stripPrefix at
# /prod/ethos-console, with other apps living at their own prod/{appname}
# on the same origin — set this to that same prefix so the browser's
# session cookie is scoped to just this app, not sent to every sibling app
# on the origin too. Leave at "/" for local dev or a deployment with no
# such prefix.
SESSION_COOKIE_PATH=/

# Entra ID (Azure AD) SSO — optional. When all four are set, the login gate
# auto-redirects unauthenticated browser requests straight to Microsoft's
# sign-in page instead of the local form above (which stays reachable
# directly at /login as a fallback). Register a Web platform app in
# entra.microsoft.com, add a client secret, and register REDIRECT_URI
# (below) byte-for-byte — protocol, host, port, path, no trailing-slash
# difference — or Microsoft refuses with AADSTS50011. See
# docs/auth-gate-guide.md's "Migrating to SSO" section.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
# e.g. http://localhost:5012/api/v1/auth/callback for local dev (the
# Doane-standard callback path, matching SF Mission Control); register the
# real deployment's URI as a second entry in Entra once ready (it keeps both).
ENTRA_REDIRECT_URI=
# ENTRA_REDIRECT_URI=

# Colleague Web API (optional — enables the Colleague API tab)
# Basic auth against the Ellucian Colleague Web API
# CTX transaction calls: POST {this}/transactions/{id}
# Must include the IIS site's own path (confirmed against a real, working
# request) — routes hang directly off it with no additional "/api/" segment,
# unlike the usual ASP.NET Web API "api/{controller}" convention.
# COLLEAGUE_WEB_API_URL=
COLLEAGUE_WEB_API_URL=https://cwsprod.doane.local:8183/ColleagueAPI
COLLEAGUE_WEB_API_USER=
COLLEAGUE_WEB_API_PASS=

# UniData / Colleague Direct Query (optional - enables the Direct Query tab)
# Connect via uopy (Rocket Software's Python API for UniData/UniVerse)
# Account path is the full server-side path to the Colleague apphome directory
UNIDATA_HOST=
UNIDATA_PORT=31438
UNIDATA_USER=
UNIDATA_PASSWORD=
UNIDATA_ACCOUNT=

# DOB Repair — optional SQL Server fetch source (app/dob_sql_source.py),
# alternative to CSV upload. Leave all unset to keep DOB Repair CSV-only.
# DOB_RECONCILE_SQL_FILE points at a .sql file you draft and own — a single
# read-only SELECT/WITH statement whose output columns match
# app/dob_detector.py's DEFAULT_COLUMNS (person_id, last_name, first_name,
# middle_name, birth_date, addr_line1, city, state, zip, email, phone,
# origin, created_date, and the optional corroborating_dob/corroborating_source
# — see the module docstring's "same-person corroboration" note). See
# docs/dob_reconcile_query.example.sql.
DOB_RECONCILE_INPUT_CSV=
DOB_RECONCILE_SQL_FILE=
# A complete ODBC connection string — this app never assembles one from
# parts, so include everything your driver needs (Encrypt/
# TrustServerCertificate too, if your SQL Server needs them).
DOB_RECONCILE_DB=DRIVER={ODBC Driver 17 for SQL Server};Server={serverNameHere};Database={databaseNameHere};UId={userNameHere};PWD={passwordHere};
# Grant DOB_RECONCILE_DB_USER SELECT-only permission on whatever reporting
# views the query touches — that DB-level permission is the real safety
# boundary, not the app's own read-only-statement guard.
# Institution-specific origin/operator codes that mark a PERSON record as
# Instant-Enroll-created, in ADDITION to app/dob_detector.py's generic
# IE_ORIGIN_VALUES defaults ("INSTANT_ENROLL"/"IE"/etc, which a real
# PERSON_ADD_OPERATOR-style column will rarely contain verbatim).
# Comma-separated. Example values confirmed against real data: a numeric web-
# registration operator ID plus the guest/cashier self-service process names.
DOB_RECONCILE_IE_ORIGIN_CODES=0420024,GUEST,WEBCASHIER

# When true, accepting a DOB Repair candidate also triggers a Conductor
# workflow that performs the actual correction (Ethos PUT + change-
# notification publish), instead of the correction only ever reaching
# Colleague via the CSV from GET /api/dob-repair/export/corrections. Off by
# default — this is a real write to a FERPA-protected field, so turn it on
# deliberately once the Conductor-side workflow below actually exists and
# has been tested.
DOB_RECONCILE_AUTO_APPLY=false
# Conductor workflow name triggered by the above — receives {person_id,
# corrected_from, corrected_to, candidate_id, reviewer}. Built/owned on the
# Conductor side, not in this app.
DOB_RECONCILE_APPLY_WORKFLOW_NAME=ethos_update_person_dob

# DoaneEdgeGate — optional. Base URL of the DOB-shift prevention reverse
# proxy in front of the Colleague Web API (see ../DoaneEdgeGate/README.md).
# The console appends /health itself and surfaces up/down on the Health tab.
# Leave unset if the gate isn't deployed yet — the tile shows "not configured"
# rather than a false "down".
EDGE_GATE_URL=

# Optional
BUS_POLL_INTERVAL=2
SILENCE_THRESHOLD_MINUTES=30
# Teams (webhook.office.com) or Slack/generic incoming webhook URL — turns
# on two alerts: a resource silent for SILENCE_THRESHOLD_MINUTES, and
# BUS_ERROR_SPIKE_THRESHOLD+ bus poll errors within an hour. Leave unset to
# keep the Bus Monitor's alerting off (its default).
BUS_ALERT_WEBHOOK_URL=
BUS_ERROR_SPIKE_THRESHOLD=10
