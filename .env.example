# Copy to .env and fill in values for local development.
# Do NOT commit .env.

# ASP.NET / API
ASPNETCORE_ENVIRONMENT=Development

ConnectionStrings__CnmDb=Server=localhost;Database=CnmDb;Trusted_Connection=True;

ColleagueWebApi__BaseUrl=https://colleague-webapi.doane.edu
ColleagueWebApi__Username=svc-cnm
ColleagueWebApi__Password=

Das__BaseUrl=
Das__Username=svc-cnm
Das__Password=

ColleagueSql__ConnectionString=

AzureAd__Authority=https://login.microsoftonline.com/<tenant-id>
AzureAd__Audience=api://<client-id>

# Ports — override here if the defaults conflict with other services
CNM_API_PORT=9501
CNM_FRONTEND_PORT=9500
# CONSOLE_PORT is read by console/start-local.ps1 as PORT
PORT=9502

# Frontend (copy to frontend/.env as well)
VITE_MSAL_CLIENT_ID=
VITE_MSAL_AUTHORITY=https://login.microsoftonline.com/<tenant-id>
VITE_MSAL_REDIRECT_URI=http://localhost:9500
VITE_API_BASE_URL=http://localhost:9501

# ── Ethos Dev Console (console/) ─────────────────────────────────────────────
# Ethos API credentials
ETHOS_API_KEY=your-ethos-api-key-here
ETHOS_BASE_URL=https://integrate.elluciancloud.com

# Console auth — set to any shared passphrase for the dev team.
# Leave blank to disable auth (localhost-only dev).
# Tip: set to the same value as CONDUCTOR_API_KEY for single sign-on.
CONSOLE_KEY=

# Conductor integration (used by the Replayer tab)
CONDUCTOR_API_KEY=
CONDUCTOR_URL=https://du-int.doane.edu/prod/conductor

# Database
# Default: SQLite file at console/instance/ethos_console.db (fine for local dev)
# Production / k8s: use a PostgreSQL URL so data survives pod restarts
# DATABASE_URL=postgresql://user:pass@localhost:5432/ethos_console
DATABASE_URL=

# Flask
FLASK_ENV=development
SECRET_KEY=dev-secret-change-in-prod
PORT=9502

# Phase 3 — UniData / Colleague Direct Query (optional)
# Requires UniData ODBC driver + pyodbc installed on the host.
# Format: DSN=ColleagueDS;UID=svc-console;PWD=<password>
UNIDATA_CONN_STR=

# Bus Monitor polling interval in seconds (default: 2)
BUS_POLL_INTERVAL=2
SILENCE_THRESHOLD_MINUTES=30
