# Copy to .env and fill in values for local development.
# Do NOT commit .env.
#
# Loaded by start-local.ps1 and the console's own start script. One file
# feeds the whole stack — the C# CNM service was folded into the Flask
# console, so there are no ASP.NET / CnmDb / AzureAd entries anymore.

# Port — Flask binds here.
PORT=5012

# All-or-nothing fixture mode. Set true to run end-to-end on fixtures
# (every upstream call returns mock data; nav shows a MOCK badge;
# X-Mock-Mode header on every response). See docs/warning.md §5.
CONSOLE_MOCK_MODE=false

# Ethos API credentials (used as the default when no environment switcher is configured)
ETHOS_API_KEY=your-ethos-api-key-here
ETHOS_BASE_URL=https://integrate.elluciancloud.com
ETHOS_GRAPHQL_API_KEY=

# Console auth — shared passphrase for the dev team.
# Leave blank to disable auth (localhost-only dev).
# Tip: set to the same value as CONDUCTOR_API_KEY for single sign-on.
CONSOLE_KEY=

# Conductor (Replay tab)
CONDUCTOR_API_KEY=
CONDUCTOR_URL=https://du-int.doane.edu/prod/conductor

# Colleague Web API (Colleague API tab + the change-notification reads
# the CN Monitor tab is now backed by — direct from Python, no CNM hop).
COLLEAGUE_WEB_API_URL=https://colleague-webapi.doane.edu
COLLEAGUE_WEB_API_USER=
COLLEAGUE_WEB_API_PASS=

# UniData / Colleague Direct Query (Direct Query tab — uses uopy)
UNIDATA_HOST=
UNIDATA_PORT=31438
UNIDATA_USER=
UNIDATA_PASSWORD=
UNIDATA_ACCOUNT=

# Database — blank => SQLite at console/instance/ethos_console.db.
# Production / k8s: use PostgreSQL so data survives pod restarts.
# DATABASE_URL=postgresql://user:pass@localhost:5432/ethos_console
DATABASE_URL=

# Flask
FLASK_ENV=development
SECRET_KEY=dev-secret-change-in-prod

# Alerting webhook (Teams or Slack)
ALERT_WEBHOOK_URL=
ALERT_ERROR_THRESHOLD=10

# Bus Monitor
BUS_POLL_INTERVAL=2
SILENCE_THRESHOLD_MINUTES=30
